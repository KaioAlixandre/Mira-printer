{
  "name": "mira-printer-agent",
  "version": "1.1.8",
  "description": "Agente Electron de impressão automática (Socket.IO + spawn script)",
  "main": "main.cjs",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "electron-updater": "^6.8.3",
    "socket.io-client": "^4.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "rcedit": "^4.0.1"
  },
  "build": {
    "appId": "com.mira.printer.agent",
    "productName": "Mira Printer Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "print-ws-server.cjs",
      "auth-session.cjs",
      "preload.cjs",
      "renderer/**/*",
      "backend/scripts/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "backend/scripts/**/*.js"
    ],
    "afterPack": "scripts/after-pack-win-icon.cjs",
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "KaioAlixandre",
        "repo": "Mira-printer",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
